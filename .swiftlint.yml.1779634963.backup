# SwiftLint Configuration
# This configuration follows best practices for excluding third-party code
# and setting reasonable defaults for a Swift project.
# Exclude common build and dependency directories
excluded:
  - .build
  - .claude
  - Pods
  - .git
  - DerivedData
  - .swiftpm
  - xcuserdata
  - .xcode
  - Packages/**/.build
  - Sources/SwiftProjectLint/ExampleViews
  - Sources/App/ExampleViews
  - ExampleCode
# Disable rules that are too strict for development
disabled_rules:
  - todo
  - inclusive_language
# Opt-in rules (enable specific rules that are valuable)
opt_in_rules:
  - empty_count
  - empty_string
  - first_where
  - force_unwrapping
  - implicitly_unwrapped_optional
  - overridden_super_call
  - prohibited_super_call
  - redundant_nil_coalescing
  - single_test_class
  - unneeded_parentheses_in_closure_argument
  - vertical_parameter_alignment_on_call
  - async_without_await
  - force_try
  - incompatible_concurrency_annotation
  - redundant_sendable
  - unowned_variable_capture
  - weak_delegate
  - private_action
  - private_outlet
  - ibinspectable_in_extension
  - discouraged_object_literal
  - toggle_bool
  - xct_specific_matcher
  - balanced_xctest_lifecycle
  - contains_over_filter_count
  - comma_inheritance
  - optional_enum_case_matching
  - discouraged_assert
  - strong_iboutlet
  - private_swiftui_state
  - file_name_no_space
  - unavailable_function
  - discouraged_optional_boolean
  - array_init
  - file_header
  - final_test_case
  - literal_expression_end_indentation
  - nslocalizedstring_require_bundle
  - empty_xctest_method
  - discouraged_none_name
  - raw_value_for_camel_cased_codable_enum
  - accessibility_trait_for_button
  - prefer_self_type_over_type_of_self
  - return_value_from_void_function
  - shorthand_argument
  - last_where
  - modifier_order
  - prefer_zero_over_explicit_init
  - flatmap_over_map_reduce
  - prefer_asset_symbols
  - private_subject
  - required_enum_case
  - local_doc_comment
  - empty_collection_literal
  - enum_case_associated_values_count
  - multiline_literal_brackets
  - static_operator
  - sorted_first_last
  - unneeded_escaping
  - test_case_accessibility
  - fallthrough
  - discarded_notification_center_observer
  - collection_alignment
  - quick_discouraged_call
  - nimble_operator
  - contains_over_first_not_nil
  - fatal_error_message
  - prohibited_interface_builder
  - quick_discouraged_focused_test
  - explicit_init
  - override_in_extension
  - quick_discouraged_pending_test
  - yoda_condition
  - object_literal
  - expiring_todo
  - lower_acl_than_parent
  - self_binding
  - untyped_error_in_catch
  - reduce_into
  - contains_over_range_nil_comparison
  - legacy_multiple
  - prefer_nimble
  - unhandled_throwing_task
  - joined_default_parameter
  - non_overridable_class_declaration
  - nslocalizedstring_key
  - number_separator
  - multiline_parameters
  - closure_spacing
  - function_default_parameter_at_end
  - operator_usage_whitespace
  - pattern_matching_keywords
  - direct_return
  - identical_operands
  - multiline_parameters_brackets
  - no_extension_access_modifier
  - redundant_self
  - strict_fileprivate
  - period_spacing
  - no_grouping_extension
  - redundant_type_annotation
  - closure_end_indentation
  - shorthand_optional_binding
  - superfluous_else
  - contains_over_filter_is_empty
  - closure_body_length
  - prefer_self_in_static_references
  - sorted_imports
  - unneeded_throws_rethrows
# Rule configurations
line_length:
  error: 150
  ignores_comments: true
  ignores_function_declarations: true
  ignores_urls: true
  warning: 120
file_length:
  error: 1000
  ignore_comment_only_lines: true
  warning: 500
function_body_length:
  error: 200
  warning: 100
function_parameter_count:
  error: 10
  warning: 6
type_body_length:
  error: 500
  warning: 300
type_name:
  max_length:
    error: 80
    warning: 60
  min_length: 3
cyclomatic_complexity:
  error: 25
  warning: 15
nesting:
  function_level: 3
  type_level: 2
large_tuple:
  error: 4
  warning: 3
# Reporter type (xcode, json, csv, checkstyle, junit, html, emoji, sonarqube, markdown)
reporter: xcode
analyzer_rules:
  - capture_variable
  - unused_import
  - unused_declaration
  - explicit_self
  - typesafe_array_init
